{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Alrimjang Data",
    "type": "object",
    "properties": {
        "dday": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {"type": "string"},
                    "date": {"type": "string", "format": "date"},
                    "emoji": {"type": "string"}
                },
                "required": ["name", "date"],
                "additionalProperties": false
            }
        },
        "school_holidays": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "date": {"type": "string", "format": "date", "description": "휴일 날짜 (YYYY-MM-DD)"},
                    "name": {"type": "string", "description": "휴일 이름 (예: 개교기념일)"}
                },
                "required": ["date", "name"],
                "additionalProperties": false
            }
        },
        "timetable": {
            "type": "object",
            "properties": {
                "monday": {"type": "array", "items": {"type": "string"}},
                "tuesday": {"type": "array", "items": {"type": "string"}},
                "wednesday": {"type": "array", "items": {"type": "string"}},
                "thursday": {"type": "array", "items": {"type": "string"}},
                "friday": {"type": "array", "items": {"type": "string"}},
                "overrides": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "date": {"type": "string", "format": "date", "description": "변경된 날짜 (YYYY-MM-DD)"},
                            "subjects": {
                                "type": "array",
                                "items": {"type": "string"},
                                "description": "해당 날짜의 시간표"
                            }
                        },
                        "required": ["date", "subjects"],
                        "additionalProperties": false
                    }
                }
            }
        }
    }
}
