{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Alrimjang Data",
    "type": "object",
    "properties": {
        "school_start_hour": {
            "type": "integer",
            "minimum": 1,
            "maximum": 23,
            "default": 9,
            "description": "등교 시간 (시 단위, 1~23)"
        },
        "dday": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {"type": "string"},
                    "date": {"type": "string", "format": "date"},
                    "emoji": {"type": "string"}
                },
                "required": ["name", "date"],
                "additionalProperties": false
            }
        },
        "school_holidays": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "date": {"type": "string", "format": "date", "description": "휴일 날짜 (YYYY-MM-DD)"},
                    "name": {"type": "string", "description": "휴일 이름 (예: 개교기념일)"}
                },
                "required": ["date", "name"],
                "additionalProperties": false
            }
        },
        "timetable": {
            "type": "object",
            "properties": {
                "monday": {"type": "array", "items": {"type": "string"}},
                "tuesday": {"type": "array", "items": {"type": "string"}},
                "wednesday": {"type": "array", "items": {"type": "string"}},
                "thursday": {"type": "array", "items": {"type": "string"}},
                "friday": {"type": "array", "items": {"type": "string"}},
                "overrides": {
                    "type": "object",
                    "description": "날짜별 시간표 부분 변경. 키: YYYY-MM-DD, 값: {교시번호: 과목명}",
                    "additionalProperties": {
                        "type": "object",
                        "description": "교시 번호(문자열)를 키로, 과목명을 값으로 가지는 객체",
                        "additionalProperties": {"type": "string"}
                    }
                }
            }
        }
    }
}
