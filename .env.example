# ──────────────────────────────
# NEIS 급식 API
# ──────────────────────────────
# https://open.neis.go.kr 에서 발급
NEIS_API_KEY=

# 시도교육청코드
ATPT_OFCDC_SC_CODE=

# 행정표준코드
SD_SCHUL_CODE=

# True = 급식 섹션 포함 / False = 급식 섹션 숨김
SCHOOL_MEAL_IGNORE=True

# ──────────────────────────────
# Open-Meteo 날씨 (학교 위치 좌표)
# ──────────────────────────────
# 학교 좌표 (Google Maps에서 확인 가능)
WEATHER_LAT=0.0
WEATHER_LON=0.0

# True = 날씨 섹션 포함 / False = 날씨 섹션 숨김
WEATHER_IGNORE=False
